---
import type { Props } from "./types.astro"

export const title = "Avatar"

const {
  alt,
  as,
  class: className,
  href,
  isGroup,
  src,
  variant,
  ...rest
} = Astro.props

const Tag = (as || (href ? "a" : "div")) as any
---

<Tag
  class:list={[
    { "ui-avatar": !isGroup },
    !isGroup && variant && `ui-${variant}`,
    className,
  ]}
  href={href}
  role={isGroup ? "group" : undefined}
  {...rest}>{src ? <img src={src} alt={alt} /> : <slot />}</Tag
>
