---
type Props = {
  [key: string]: any
  alt?: string
  as?: "div" | "a" | "button" | string
  class?: string
  href?: string
  isGroup?: boolean
  spacing?: "small" | "x-small"
  src?: string
  variant?: "squared" | "rounded" | "squircle"
}

export const title = "Avatar"

const {
  alt,
  as,
  class: className,
  href,
  isGroup,
  spacing,
  src,
  variant,
  ...rest
} = Astro.props

const Tag = as || (href ? "a" : "div")
---

<!-- prettier-ignore -->
<Tag
  class:list={[
    { "ui-avatar": !isGroup },
    !isGroup && variant && `ui-${variant}`,
    {
      "gap-small": isGroup && spacing === "small",
      "gap-x-small": isGroup && spacing === "x-small",
    },
    className,
  ]}
  href={href}
  role={isGroup ? "group" : undefined}
  {...rest}>{src ? <img src={src} alt={alt} /> : <slot />}</Tag>
