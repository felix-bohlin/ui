---
import type { Props } from './types.ts'


export const title = "Avatar"

const {
  alt,
  as,
  class: className,
  href,
  isGroup,
  spacing,
  src,
  variant,
  ...rest
} = Astro.props

const Tag = (as || (href ? "a" : "div")) as any

---

<!-- prettier-ignore -->
<Tag
  class:list={[
    { avatar: !isGroup },
    !isGroup && variant,
    {
      "gap-small": isGroup && spacing === "small",
      "gap-x-small": isGroup && spacing === "x-small",
    },
    className,
  ]}
  href={href}
  role={isGroup ? "group" : undefined}
  {...rest}>{src ? <img src={src} alt={alt} /> : <slot />}</Tag>
