---
import type { Props } from "./types.astro"

import Anchor from "../Anchor/Anchor.astro"

export const title = "Badge"

const {
  alignment,
  class: className,
  color,
  dot,
  invisible,
  label,
  ...rest
} = Astro.props

const positionArea =
  alignment === "start-start"
    ? "start start"
    : alignment === "end-start"
      ? "end start"
      : alignment === "end-end"
        ? "end end"
        : undefined

---

<Anchor
  alignment={positionArea}
  class:list={[
    "ui-badge",
    {
      "ui-dot": dot,
      "ui-invisible": invisible,
    },
    alignment && `ui-${alignment}`,
    className,
    color && `ui-${color}`,
  ]}
  {...rest as any}
>
  <slot />
  <span
    class="ui-badge-indicator"
    slot="anchored"
    aria-label={label?.toString()}
  >
    {dot ? "" : label}
    {!dot && <slot name="indicator" />}
  </span>
</Anchor>
