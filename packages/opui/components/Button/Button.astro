---
import type { Props } from "./types.astro"

export const title = "Button"

const props = Astro.props as Props
const { as, class: className, color, size, variant, ...rest } = props

const Tag = as || ("href" in props ? "a" : "button")
---

<Tag
  class:list={[
    "button",
    { disabled: props.as === "button" && props.disabled },
    size,
    variant,
    color,
    className,
  ]}
  disabled={props.as === "button" ? props.disabled : undefined}
  {...rest as any}
>
  <slot />
</Tag>
