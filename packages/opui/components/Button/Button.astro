---
import { prefix } from "../../css/js/prefix.js"
type CommonProps = {
  [key: string]: any
  as?: string
  class?: string
  color?: "critical" | "primary"
  size?: "x-small" | "small" | "large"
  variant?: "outlined" | "tonal" | "filled"
}

type AnchorProps = CommonProps & {
  disabled?: never
  href: string
}

type ButtonProps = CommonProps & {
  disabled?: boolean
  href?: undefined
}

type Props = AnchorProps | ButtonProps

export const title = "Button"

const {
  as,
  class: className,
  color,
  disabled,
  href,
  size,
  variant,
  ...rest
} = Astro.props

const Tag = as || (href ? "a" : "button")
const isButton = Tag === "button"
---

<!-- prettier-ignore -->
<Tag
  class:list={[prefix("button", { disabled: isButton && disabled }, size, variant, color ), className]}
  disabled={isButton ? disabled : undefined}
  href={href}
  {...rest}><slot /></Tag>
