---
import type { Props } from "./types.astro"

export const title = "Button"

const props = Astro.props as Props
const { as, class: className, color, size, variant, disabled, href, ...rest } = props

const Tag = as || (href ? "a" : "button")
const isButton = Tag === "button"
---

<Tag
  class:list={[
    "ui-button",
    { "ui-disabled": isButton && disabled },
    size && `ui-${size}`,
    variant && `ui-${variant}`,
    color && `ui-${color}`,
    className,
  ]}
  disabled={isButton ? disabled : undefined}
  href={href}
  {...rest as any}
>
  <slot />
</Tag>
