---
import type { Props } from './types.ts'





export const title = "Button"

const {
  as,
  class: className,
  color,
  disabled,
  href,
  size,
  variant,
  ...rest
} = Astro.props

const Tag = as || (href ? "a" : "button")
const isButton = Tag === "button"

---

<!-- prettier-ignore -->
<Tag
  class:list={["button", { disabled: isButton && disabled }, size, variant, color, className]}
  disabled={isButton ? disabled : undefined}
  href={href}
  {...rest}><slot /></Tag>
