---
import { prefixClasses as pfx } from "../utils";
type Props = {
  [key: string]: any
  class?: string
  color?: "critical" | "primary"
  orientation?: "vertical"
  size?: "small" | "large"
  variant?: "outlined" | "tonal" | "filled"
}

export const title = "Button Group"

const {
  class: className,
  color,
  orientation,
  size,
  variant,
  ...rest
} = Astro.props
---

<div
  class:list={pfx(["button-group", color, size, variant, orientation, className])}
  role="group"
  {...rest}
>
  <slot />
</div>
