---
import type { Props } from "./types"

export const title = "Button Group"

const {
  class: className,
  color,
  orientation,
  size,
  variant,
  ...rest
} = Astro.props
---

<div
  class:list={["ui-button-group", color && `ui-${color}`, size && `ui-${size}`, variant && `ui-${variant}`, orientation && `ui-${orientation}`, className]}
  role="group"
  {...rest}
>
  <slot />
</div>
