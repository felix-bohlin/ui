---
import type { Props } from "./types"

export const title = "Button Group"

const {
  class: className,
  color,
  orientation,
  size,
  variant,
  ...rest
} = Astro.props
---

<div
  class:list={["button-group", color, size, variant, orientation, className]}
  role="group"
  {...rest}
>
  <slot />
</div>
