---
type Props = {
  [key: string]: any
  class?: string
  color?: "critical" | "primary"
  orientation?: "vertical"
  size?: "small" | "large"
  variant?: "outlined" | "tonal" | "filled"
}

export const title = "Button Group"

const {
  class: className,
  color,
  orientation,
  size,
  variant,
  ...rest
} = Astro.props
---

<div
  class:list={[
    "ui-button-group",
    color && `ui-${color}`,
    size && `ui-${size}`,
    variant && `ui-${variant}`,
    orientation && `ui-${orientation}`,
    className,
  ]}
  role="group"
  {...rest}
>
  <slot />
</div>
