---
import { prefix } from "../../css/js/prefix.js"
type Props = {
  variant?: "text" | "outlined" | "elevated" | "tonal"
  actions?: {
    align?: "end"
  }
  [key: string]: any
}

export const title = "Card"

const { variant, actions, class: className, ...rest } = Astro.props
---

<div class:list={prefix("card", variant, className)} {...rest}>
  {
    Astro.slots.has("header") && (
      <hgroup>
        <slot name="header" />
      </hgroup>
    )
  }
  {
    Astro.slots.has("content") && (
      <div class="content">
        <slot name="content" />
      </div>
    )
  }
  <slot />
  {
    Astro.slots.has("actions") && (
      <div
        class:list={prefix(
          "actions",
          actions?.align && `align-${actions.align}`,
        )}
      >
        <slot name="actions" />
      </div>
    )
  }
</div>
