---
import { prefix } from "../../css/js/prefix.js"
type Props = {
  actionsAlign?: "start" | "end"
  variant?: "text" | "outlined" | "elevated" | "tonal"
  [key: string]: any
}

export const title = "Card"

const { variant, actionsAlign, class: className, ...rest } = Astro.props
---

<div class:list={prefix("card", variant, className)} {...rest}>
  {
    Astro.slots.has("header") && (
      <hgroup>
        <slot name="header" />
      </hgroup>
    )
  }
  {
    Astro.slots.has("content") && (
      <div class="content">
        <slot name="content" />
      </div>
    )
  }
  <slot />
  {
    Astro.slots.has("actions") && (
      <div
        class:list={prefix("actions", actionsAlign && `align-${actionsAlign}`)}
      >
        <slot name="actions" />
      </div>
    )
  }
</div>
