---
import { prefixClasses as pfx } from "../utils";
type Props = {
  variant?: "text" | "outlined" | "elevated" | "tonal"
  actions?: {
    align?: "end"
  }
  [key: string]: any
}

export const title = "Card"

const { variant, actions, class: className, ...rest } = Astro.props
---

<div class:list={pfx(["card", variant, className])} {...rest}>
  {
    Astro.slots.has("header") && (
      <hgroup>
        <slot name="header" />
      </hgroup>
    )
  }
  {
    Astro.slots.has("content") && (
      <div class="content">
        <slot name="content" />
      </div>
    )
  }
  <slot />
  {
    Astro.slots.has("actions") && (
      <div class:list={pfx(["actions", actions?.align && `align-${actions.align}`])}>
        <slot name="actions" />
      </div>
    )
  }
</div>
