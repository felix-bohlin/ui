---
type Props = {
  actionsAlign?: "start" | "end"
  variant?: "text" | "outlined" | "elevated" | "tonal"
  [key: string]: any
}

export const title = "Card"

const { variant, actionsAlign, class: className, ...rest } = Astro.props
---

<div class:list={["ui-card", variant && `ui-${variant}`, className]} {...rest}>
  {
    Astro.slots.has("header") && (
      <hgroup>
        <slot name="header" />
      </hgroup>
    )
  }
  {
    Astro.slots.has("content") && (
      <div class="ui-content">
        <slot name="content" />
      </div>
    )
  }
  <slot />
  {
    Astro.slots.has("actions") && (
      <div class:list={["ui-actions", actionsAlign && `ui-align-${actionsAlign}`]}>
        <slot name="actions" />
      </div>
    )
  }
</div>
