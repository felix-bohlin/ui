---
import type { CheckboxProps as Props } from './types.astro';
import CheckboxInput from "./CheckboxInput.astro"

export const title = "Checkbox"

const {
  class: className,
  critical,
  hideLabel,
  name,
  size,
  spread,
  stack,
  ...rest
} = Astro.props

const { $id, currentFieldName } = Astro.locals
const endTextId = Astro.slots.has("end-text") ? $id("end-text") : undefined

const finalName = name || currentFieldName
---

<label
  class:list={[
    "checkbox",
    size,
    {
      stack,
      spread,
    },
    className,
  ]}
  data-invalid={critical || undefined}
>
  <CheckboxInput
    aria-describedby={endTextId}
    name={finalName}
    {...rest}
  />
  <!-- prettier-ignore --><span class:list={[hideLabel ? "sr-only" : "label"]}><slot /></span>
  {
    Astro.slots.has("end-text") && (
      <!-- prettier-ignore -->
      <span id={endTextId} class="end-text"><slot name="end-text" /></span>
    )
  }
</label>
