---
import type { CheckboxInputProps as Props } from "./types.astro"

const { indeterminate, ...rest } = Astro.props as Props
---

<input
  type="checkbox"
  data-indeterminate={indeterminate || undefined}
  {...rest}
/>

<script>
  import { initCheckbox } from "../../css/js/checkbox.js"
  initCheckbox()
</script>
