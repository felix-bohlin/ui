---
import type { CheckboxInputProps as Props } from "./types.ts"

const { checked, disabled, id, indeterminate, name, required, value, ...rest } =
  Astro.props
---

<input
  type="checkbox"
  data-indeterminate={indeterminate || undefined}
  {checked}
  {disabled}
  {id}
  {name}
  {required}
  {value}
  {...rest}
/>

<script>
  import { initCheckbox } from "../../css/js/checkbox.js"
  initCheckbox()
</script>
