---
import type { Props } from './types.ts'


export const title = "Chip"

const {
  as: Tag = Astro.props.href ? "a" : "div",
  class: className,
  label,
  multiline,
  size,
  variant = "tonal",
  ...rest
} = Astro.props

---

<!-- prettier-ignore -->
<Tag
  class:list={[
    "chip",
    {
      multiline,
    },
    size,
    variant,
    className,
  ]}
  {...rest}
><slot name="start" /><slot />{label && <span class="text">{label}</span>}<slot name="end" /></Tag>
