---
import type { Props } from './types.astro'


export const title = "Chip"

const {
  as: Tag = Astro.props.href ? "a" : "div",
  class: className,
  label,
  multiline,
  size,
  variant = "tonal",
  ...rest
} = Astro.props

---

<!-- prettier-ignore -->
<Tag
  class:list={[
    "ui-chip",
    {
      "ui-multiline": multiline,
    },
    size && `ui-${size}`,
    variant && `ui-${variant}`,
    className,
  ]}
  {...rest}
><slot name="start" /><slot />{label && <span class="ui-text">{label}</span>}<slot name="end" /></Tag>
