---
type Item = {
  text: string
  value: any
}

type Props = {
  [key: string]: any
  class?: string
  disabled?: boolean
  critical?: boolean
  id?: string
  items?: Item[]
  label?: string
  name?: string
  required?: boolean
  size?: "small"
  endText?: string
  value?: any
  variant?: "outlined" | "filled"
}

export const title = "Classic Select"

const {
  class: className,
  disabled,
  critical,
  id,
  items = [],
  label,
  name,
  required,
  size,
  endText,
  value,
  variant = "outlined",
  ...rest
} = Astro.props

const { $id } = Astro.locals
const selectId = id || $id("select")
const labelId = $id("select-label")
---

<label
  class:list={[
    "ui-select",
    size && `ui-${size}`,
    {
      "ui-filled": variant === "filled",
    },
    className,
  ]}
  data-invalid={critical || undefined}
>
  {
    label && (
      <!-- prettier-ignore -->
      <span class="ui-label" id={labelId}>{label}</span>
    )
  }
  <span class="ui-field">
    <select
      aria-labelledby={label ? labelId : undefined}
      disabled={disabled}
      id={selectId}
      name={name}
      required={required}
      value={value}
      {...rest}
    >
      {items.map((item) => <option value={item.value}>{item.text}</option>)}
      <slot />
    </select>
  </span>
  {
    endText && (
      <!-- prettier-ignore -->
      <span class="ui-end-text">{endText}</span>
    )
  }
</label>
