---
type Props = {
  [key: string]: any
  bordered?: boolean | "dotted"
  class?: string
}

export const title = "Description List"

const { bordered, class: className, ...rest } = Astro.props
---

<dl
  class:list={[
    "ui-description-list",
    { "ui-bordered": bordered, "ui-dotted": bordered === "dotted" },
    className,
  ]}
  {...rest}
>
  <slot />
</dl>
