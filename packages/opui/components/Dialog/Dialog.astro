---
import { prefix } from "../../css/js/prefix.js"
type Props = {
  [key: string]: any
  actionsAlign?: "start" | "end"
  class?: string
  closedby?: "any" | "closerequest" | "none"
}

export const title = "Dialog"

const { actionsAlign, class: className, closedby, ...rest } = Astro.props
---

<dialog
  class:list={[prefix("dialog card elevated"), className]}
  closedby={closedby}
  {...rest}
>
  {
    Astro.slots.has("header") && (
      <hgroup>
        <slot name="header" />
      </hgroup>
    )
  }
  {
    Astro.slots.has("content") && (
      <div class="content">
        <slot name="content" />
      </div>
    )
  }
  <slot />
  {
    Astro.slots.has("actions") && (
      <div
        class:list={prefix("actions", actionsAlign && `align-${actionsAlign}`)}
      >
        <slot name="actions" />
      </div>
    )
  }
</dialog>
