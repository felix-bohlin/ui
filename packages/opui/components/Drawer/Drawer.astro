---
import type { Props } from "./types.astro"

export const title = "Drawer"

const {
  backdrop = "blurred",
  class: className,
  closedby = "any",
  id,
  scrollLock = true,
  side = "inline-start",
  ...rest
} = Astro.props

const { $id } = Astro.locals
const drawerId = id || $id("drawer")
---

<dialog
  closedby={closedby}
  class:list={[
    "ui-drawer",
    side && `ui-${side}`,
    {
      "ui-backdrop-transparent": backdrop === "transparent",
      "ui-scroll-lock": scrollLock,
    },
    className,
  ]}
  id={drawerId}
  {...rest}
>
  {Astro.slots.has("header") && <slot name="header" />}

  {
    Astro.slots.has("content") && (
      <div class="ui-content">
        <slot name="content" />
      </div>
    )
  }

  <slot />

  {Astro.slots.has("footer") && <slot name="footer" />}
</dialog>
