---
import type { Props } from "./types.astro"
export const title = "Field Group"

const { class: className, direction, name, ...rest } = Astro.props
const originalName = Astro.locals.currentFieldName
if (name) {
  Astro.locals.currentFieldName = name
}

let html = ""
try {
  html = await Astro.slots.render("default")
} finally {
  Astro.locals.currentFieldName = originalName
}
---

<div
  class:list={["ui-field-group", direction && `ui-${direction}`, className]}
  {...rest}
  role="group"
  set:html={html}
/>
