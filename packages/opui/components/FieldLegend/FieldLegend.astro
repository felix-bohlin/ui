---
import type { FieldLegendProps as Props } from "./types.ts"

export const title = "Field Legend"

const { as: Tag = "legend", class: className, ...rest } = Astro.props
const isLegend = Tag === "legend"
---

<!-- prettier-ignore -->
<Tag class:list={[{ legend: !isLegend }, className]} {...rest}><slot /></Tag>
