---
import { prefix } from "../../css/js/prefix"
type Props = {
  [key: string]: any
  as?: "fieldset" | "div" | string
  class?: string
}

export const title = "Field Set"

const { as: Tag = "fieldset", class: className, ...rest } = Astro.props
---

<Tag class:list={[prefix("fieldset"), className]} {...rest}>
  <slot />
</Tag>
