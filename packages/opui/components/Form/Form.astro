---
import { prefixClasses as pfx } from "../utils";
type Props = {
  [key: string]: any
  as?: "form" | "div" | string
  class?: string
}

export const title = "Form"

const { as: Tag = "form", class: className, ...rest } = Astro.props
---

<Tag class:list={pfx(["form", className])} {...rest}>
  <slot />
</Tag>
