---
import { prefix } from "../../css/js/prefix.js"
type Props = {
  [key: string]: any
  as?: "form" | "div" | string
  class?: string
}

export const title = "Form"

const { as: Tag = "form", class: className, ...rest } = Astro.props
---

<Tag class:list={prefix("form", className)} {...rest}>
  <slot />
</Tag>
