---
import type { Props } from "./types.astro"

export const title = "Icon Button"

const props = Astro.props as Props
const { as, class: className, color, size, variant, ...rest } = props

const Tag = as || ("href" in props ? "a" : "button")
---

<!-- prettier-ignore -->
<Tag class:list={["icon-button", size, variant, color, className]} {...rest as any}><slot /></Tag>
