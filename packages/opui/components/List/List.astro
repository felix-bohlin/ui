---
import type { Props } from "./types.astro"
export const title = "List"

const {
  bordered,
  class: className,
  dense,
  gutterless,
  variant,
  ...rest
} = Astro.props
---

<ul
  class:list={[
    "ui-list",
    {
      "ui-bordered": bordered,
      "ui-dense": dense,
      "ui-gutterless": gutterless,
    },
    variant && `ui-${variant}`,
    className,
  ]}
  {...rest}
>
  <slot />
</ul>
