---
import type { Props } from "./types"

export const title = "List"

const {
  bordered,
  class: className,
  dense,
  gutterless,
  variant,
  ...rest
} = Astro.props
---

<ul
  class:list={[
    "list",
    {
      bordered,
      dense,
      gutterless,
    },
    variant,
    className,
  ]}
  {...rest}
>
  <slot />
</ul>
