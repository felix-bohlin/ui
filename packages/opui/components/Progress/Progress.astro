---
type Props = {
  [key: string]: any
  "aria-busy"?: "true" | "false" | boolean
  "aria-describedby"?: string
  "aria-label"?: string
  class?: string
  id?: string
  max?: number | string
  value?: number | string
  variant?: "filled" | "default" | "tonal"
}

export const title = "Progress"

const {
  "aria-busy": ariaBusy,
  "aria-describedby": ariaDescribedby,
  "aria-label": ariaLabel,
  class: className,
  id,
  max,
  value,
  variant,
  ...rest
} = Astro.props
---

<div class:list={["ui-progress", className, variant && `ui-${variant}`]}>
  <progress
    aria-busy={ariaBusy}
    aria-describedby={ariaDescribedby}
    aria-label={ariaLabel}
    id={id}
    max={max}
    value={value}
    {...rest}
  >
    <slot />
  </progress>
</div>
