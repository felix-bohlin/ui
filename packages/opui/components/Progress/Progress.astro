---
import type { Props } from "./types.astro"

export const title = "Progress"

const { class: className, max, value, variant, ...rest } = Astro.props
---

<div class:list={["ui-progress", className, variant && `ui-${variant}`]}>
  <progress max={max} value={value} {...rest}>
    <slot />
  </progress>
</div>
