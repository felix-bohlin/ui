---
import type { Props } from './types.ts'


export const title = "Progress"

const {
  "aria-busy": ariaBusy,
  "aria-describedby": ariaDescribedby,
  "aria-label": ariaLabel,
  class: className,
  id,
  max,
  value,
  variant,
  ...rest
} = Astro.props

---

<progress
  aria-busy={ariaBusy}
  aria-describedby={ariaDescribedby}
  aria-label={ariaLabel}
  class:list={["progress", className, variant]}
  id={id}
  max={max}
  value={value}
  {...rest}
>
  <slot />
</progress>
