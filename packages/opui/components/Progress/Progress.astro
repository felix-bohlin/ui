---
import { prefix } from "../../css/js/prefix.js"
type Props = {
  [key: string]: any
  "aria-busy"?: "true" | "false" | boolean
  "aria-describedby"?: string
  "aria-label"?: string
  class?: string
  id?: string
  max?: number | string
  value?: number | string
  variant?: "filled" | "default" | "tonal"
}

export const title = "Progress"

const {
  "aria-busy": ariaBusy,
  "aria-describedby": ariaDescribedby,
  "aria-label": ariaLabel,
  class: className,
  id,
  max,
  value,
  variant,
  ...rest
} = Astro.props
---

<progress
  aria-busy={ariaBusy}
  aria-describedby={ariaDescribedby}
  aria-label={ariaLabel}
  class:list={[prefix("progress", variant), className]}
  id={id}
  max={max}
  value={value}
  {...rest}
>
  <slot />
</progress>
