---
import type { RadioProps as Props } from './types.astro'
import RadioInput from "./RadioInput.astro"

export const title = "Radio"

const {
  class: className,
  error,
  hideLabel,
  name,
  size,
  stack,
  ...rest
} = Astro.props

const { $id, currentFieldName } = Astro.locals
const endTextId = Astro.slots.has("end-text") ? $id("end-text") : undefined

const finalName = name || currentFieldName
---

<label
  class:list={[
    "ui-radio",
    size && `ui-${size}`,
    {
      "ui-stack": stack,
    },
    className,
  ]}
  data-invalid={error || undefined}
>
  <RadioInput
    aria-describedby={endTextId}
    name={finalName}
    {...rest}
  />
  <!-- prettier-ignore --><span class:list={[hideLabel ? "ui-sr-only" : "ui-label"]}><slot /></span>
  {
    Astro.slots.has("end-text") && (
      <!-- prettier-ignore -->
      <span id={endTextId} class="ui-end-text"><slot name="end-text" /></span>
    )
  }
</label>
