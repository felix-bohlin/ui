---
type Props = {
  [key: string]: any
  checked?: boolean
  disabled?: boolean
  id?: string
  name?: string
  required?: boolean
  value?: string
}

const { checked, disabled, id, name, required, value, ...rest } = Astro.props
---

<input
  type="radio"
  {checked}
  {disabled}
  {id}
  {name}
  {required}
  {value}
  {...rest}
/>
