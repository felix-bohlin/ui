---
import { prefix } from "../../css/js/prefix"
type Props = {
  [key: string]: any
  class?: string
  disabled?: boolean
  endText?: string
  id?: string
  label?: string
  max?: number | string
  min?: number | string
  name?: string
  spread?: boolean
  startText?: string
  step?: number | string
  value?: number | string
  valueSuffix?: string
  variant?: "filled" | "default" | "tonal"
} & (
  | { list?: never; options?: never }
  | {
      list: string
      options: (string | number | { value: string | number; label?: string })[]
    }
)

export const title = "Range"

const {
  class: className,
  disabled,
  endText,
  id,
  label,
  list,
  max,
  min,
  name,
  options,
  spread,
  startText,
  step,
  value,
  valueSuffix,
  variant,
  ...rest
} = Astro.props

const { $id } = Astro.locals

const hasLabel = !!label || Astro.slots.has("default")
const hasStartText = !!startText || Astro.slots.has("start-text")
const hasEndText = !!endText || Astro.slots.has("end-text")
const hasValue = valueSuffix !== undefined || Astro.slots.has("value")

const inputId = id || $id("range")
const labelId = hasLabel ? $id("range-label") : undefined
const startTextId = hasStartText ? $id("range-start") : undefined
const endTextId = hasEndText ? $id("range-end") : undefined

const describedBy = [startTextId, endTextId].filter(Boolean).join(" ") || undefined
---

<label class:list={[prefix("range", variant, { spread }), className]}>
  {
    hasLabel && (
      <!-- prettier-ignore -->
      <span class="label" id={labelId}>{label}<slot /></span>
    )
  }
  {
    hasValue && (
      <output class="value" for={inputId} data-suffix={valueSuffix}>
        <slot name="value">{value}</slot>
      </output>
    )
  }
  {
    hasStartText && (
      <span class="start-text" id={startTextId}>
        {startText}<slot name="start-text" />
      </span>
    )
  }
  <input
    aria-describedby={describedBy}
    aria-labelledby={labelId}
    disabled={disabled}
    id={inputId}
    list={list}
    max={max}
    min={min}
    name={name}
    step={step}
    type="range"
    value={value}
    {...rest}
  />
  {
    (options || Astro.slots.has("datalist")) && (
      <datalist id={list}>
        {options?.map((option) =>
          typeof option === "object" ? (
            <option value={option.value} label={option.label} />
          ) : (
            <option value={option} />
          )
        )}
        <slot name="datalist" />
      </datalist>
    )
  }
  {
    hasEndText && (
      <span class="end-text" id={endTextId}>
        {endText}<slot name="end-text" />
      </span>
    )
  }
</label>

<script>
  // Mirror the slider's current value into its associated <output> on every
  // input event. Idempotent: each .range is wired once, and ignores ranges
  // without a value display.
  for (const range of document.querySelectorAll<HTMLElement>(".range")) {
    const input = range.querySelector<HTMLInputElement>('input[type="range"]')
    const output = range.querySelector<HTMLOutputElement>(":scope > output.value")
    if (!input || !output) continue
    const suffix = output.dataset.suffix ?? ""
    const update = () => {
      output.textContent = `${input.value}${suffix}`
    }
    input.addEventListener("input", update)
    update()
  }
</script>
