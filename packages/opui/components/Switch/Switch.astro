---
import SwitchInput from "./SwitchInput.astro"
import type { SwitchProps as Props } from './types.astro'

export const title = "Switch"

const {
  class: className,
  error,
  hideLabel,
  name,
  small,
  spread,
  stack,
  ...rest
} = Astro.props

const { $id, currentFieldName } = Astro.locals
const endTextId = Astro.slots.has("end-text") ? $id("end-text") : undefined

const finalName = name || currentFieldName

if (
  import.meta.env.DEV &&
  !Astro.slots.has("default") &&
  !Astro.props["aria-label"] &&
  !Astro.props["aria-labelledby"]
) {
  console.warn(
    "[OPUI Switch] Missing accessible name. Provide a default slot, `aria-label`, or `aria-labelledby`."
  )
}
---

<label
  class:list={[
    "ui-switch",
    {
      "ui-small": small,
      "ui-stack": stack,
      "ui-spread": spread,
    },
    className,
  ]}
  data-invalid={error || undefined}
>
  {
    Astro.slots.has("icon-unchecked") && (
      <span class="ui-icon-unchecked" aria-hidden="true">
        <slot name="icon-unchecked" />
      </span>
    )
  }
  {
    Astro.slots.has("icon-checked") && (
      <span class="ui-icon-checked" aria-hidden="true">
        <slot name="icon-checked" />
      </span>
    )
  }
  <SwitchInput
    aria-describedby={endTextId}
    name={finalName}
    {...rest}
  />
  {
    Astro.slots.has("default") && (
    <!-- prettier-ignore --><span class:list={[hideLabel ? "ui-sr-only" : "ui-label"]}><slot /></span>)
  }
    {
      Astro.slots.has("end-text") && (
        <!-- prettier-ignore -->
        <span id={endTextId} class="ui-end-text"><slot name="end-text" /></span>
      )
    }
</label>
