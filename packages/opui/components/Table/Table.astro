---
import { prefix } from "../../css/js/prefix.js"
type Props = {
  [key: string]: any
  class?: string
  variant?: "dense" | "spacious"
}

export const title = "Table"

const { class: className, variant, ...rest } = Astro.props
---

<table class:list={prefix(className, variant)} {...rest}>
  <slot />
</table>
