---
import { prefixClasses as pfx } from "../utils";
type Props = {
  class?: string
  panelId?: string
  tabId?: string
  [key: string]: any
}

const { class: className, panelId, tabId, ...rest } = Astro.props
const { currentPanelId, currentTabId } = Astro.locals
---

<div
  id={panelId || currentPanelId}
  class:list={pfx(["tab-panel", className])}
  role="tabpanel"
  aria-labelledby={tabId || currentTabId}
  {...rest}
>
  <slot />
</div>
