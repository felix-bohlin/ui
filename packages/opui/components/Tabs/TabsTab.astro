---
import { prefix } from "../../css/js/prefix.js"
type Props = {
  class?: string
  tabId?: string
  [key: string]: any
}

const { class: className, tabId, ...rest } = Astro.props
const { currentTabId } = Astro.locals
---

<label
  for={tabId || currentTabId}
  class:list={prefix("tab-label", className)}
  role="tab"
  {...rest}
>
  <slot />
</label>
