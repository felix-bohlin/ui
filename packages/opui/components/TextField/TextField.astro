---
import type { TextFieldProps as Props } from "./types.ts"

export const title = "Text Field"

const {
  autoFit,
  class: className,
  critical,
  description,
  disabled,
  endText,
  filled,
  id,
  label,
  list,
  max,
  min,
  name,
  placeholder,
  required,
  small,
  spread,
  startText,
  step,
  type = "text",
  value,
  ...rest
} = Astro.props

const startTextValue = description || startText
const { $id, currentFieldName } = Astro.locals
const fieldId = id || $id("text-field")
const fieldName = name || currentFieldName
---

<label
  class:list={[
    "text-field",
    {
      "auto-fit": autoFit,
      filled,
      spread,
      small,
    },
    className,
  ]}
  data-invalid={critical || undefined}
  {...rest}
>
  {
    (label || Astro.slots.has("label")) && (
      <!-- prettier-ignore -->
      <span class="label">{label}<slot name="label" /></span>
    )
  }
  {
    (startTextValue || Astro.slots.has("description")) && (
      <!-- prettier-ignore -->
      <span class="start-text">{startTextValue}<slot name="description" /></span>
    )
  }
  <span class="field">
    <input
      disabled={disabled}
      id={fieldId}
      inputmode={type === "numeric" ? "numeric" : undefined}
      list={list}
      max={max}
      min={min}
      name={fieldName}
      pattern={type === "numeric" ? "[0-9]*" : undefined}
      placeholder={placeholder}
      required={required}
      step={step}
      type={type === "numeric" ? "text" : type}
      value={value}
    />
    {Astro.slots.has("prefix") && <span class="prefix"><slot name="prefix" /></span>}
    {Astro.slots.has("suffix") && <span class="suffix"><slot name="suffix" /></span>}
    {Astro.slots.has("header") && <span class="header"><slot name="header" /></span>}
    {Astro.slots.has("footer") && <span class="footer"><slot name="footer" /></span>}
  </span>
  {
    (endText || Astro.slots.has("end-text") || Astro.slots.has("supporting-text")) && (
      <!-- prettier-ignore -->
      <span class="end-text">{endText}<slot name="end-text" /><slot name="supporting-text" /></span>
    )
  }
  <slot />
</label>
