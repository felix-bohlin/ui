---
import type { Props } from "./types.astro"

export const title = "Text Field"

const {
  autoFit,
  class: className,
  error,
  description,
  disabled,
  endText,
  filled,
  id,
  label,
  list,
  max,
  min,
  name,
  placeholder,
  required,
  small,
  spread,
  startText,
  step,
  type = "text",
  value,
  ...rest
} = Astro.props

const startTextValue = description || startText
const { $id, currentFieldName } = Astro.locals
const fieldId = id || $id("text-field")
const fieldName = name || currentFieldName
---

<label
  class:list={[
    "ui-text-field",
    {
      "ui-auto-fit": autoFit,
      "ui-filled": filled,
      "ui-spread": spread,
      "ui-small": small,
    },
    className,
  ]}
  data-invalid={error || undefined}
  {...rest}
>
  {
    (label || Astro.slots.has("label")) && (
      <span class="ui-label">
        {label}
        <slot name="label" />
      </span>
    )
  }
  {
    (startTextValue || Astro.slots.has("description")) && (
      <span class="ui-start-text">
        {startTextValue}
        <slot name="description" />
      </span>
    )
  }
  <span class="ui-field">
    <input
      disabled={disabled}
      id={fieldId}
      inputmode={type === "numeric" ? "numeric" : undefined}
      list={list}
      max={max}
      min={min}
      name={fieldName}
      pattern={type === "numeric" ? "[0-9]*" : undefined}
      placeholder={placeholder}
      required={required}
      step={step}
      type={type === "numeric" ? "text" : type}
      value={value}
    />
    {
      Astro.slots.has("prefix") && (
        <span class="ui-prefix">
          <slot name="prefix" />
        </span>
      )
    }
    {
      Astro.slots.has("suffix") && (
        <span class="ui-suffix">
          <slot name="suffix" />
        </span>
      )
    }
    {
      Astro.slots.has("header") && (
        <span class="ui-header">
          <slot name="header" />
        </span>
      )
    }
    {
      Astro.slots.has("footer") && (
        <span class="ui-footer">
          <slot name="footer" />
        </span>
      )
    }
  </span>
  {
    (endText ||
      Astro.slots.has("end-text") ||
      Astro.slots.has("supporting-text")) && (
      <span class="ui-end-text">
        {endText}
        <slot name="end-text" />
        <slot name="supporting-text" />
      </span>
    )
  }
  <slot />
</label>
