---
import type { Props } from "./types.astro"

export const title = "Textarea"

const {
  autoFit,
  class: className,
  cols,
  description,
  disabled,
  error,
  filled,
  id,
  label,
  maxlength,
  minlength,
  name,
  spread,
  placeholder,
  required,
  rows,
  small,
  endText,
  value,
  ...rest
} = Astro.props

const { $id, currentFieldName } = Astro.locals
const fieldId = id || $id("textarea")
const fieldName = name || currentFieldName
---

<label
  class:list={[
    "ui-textarea",
    {
      "ui-auto-fit": autoFit,
      "ui-filled": filled,
      "ui-spread": spread,
      "ui-small": small,
    },
    className,
  ]}
  data-invalid={error || undefined}
  {...rest}
>
  {
    (label || Astro.slots.has("label")) && (
      <span class="ui-label">
        {label}
        <slot name="label" />
      </span>
    )
  }

  {
    (description || Astro.slots.has("description")) && (
      <span class="ui-start-text">
        {description}
        <slot name="description" />
      </span>
    )
  }
  <span class="ui-field">
    <textarea
      cols={cols}
      disabled={disabled}
      id={fieldId}
      maxlength={maxlength}
      minlength={minlength}
      name={fieldName}
      placeholder={placeholder}
      required={required}
      rows={rows}
      value={value}></textarea>
    {
      Astro.slots.has("prefix") && (
        <span class="ui-prefix">
          <slot name="prefix" />
        </span>
      )
    }
    {
      Astro.slots.has("suffix") && (
        <span class="ui-suffix">
          <slot name="suffix" />
        </span>
      )
    }
    {
      Astro.slots.has("header") && (
        <span class="ui-header">
          <slot name="header" />
        </span>
      )
    }
    {
      Astro.slots.has("footer") && (
        <span class="ui-footer">
          <slot name="footer" />
        </span>
      )
    }
  </span>
  {
    (endText ||
      Astro.slots.has("end-text") ||
      Astro.slots.has("supporting-text")) && (
      <span class="ui-end-text">
        {endText}
        <slot name="end-text" />
        <slot name="supporting-text" />
      </span>
    )
  }
  <slot />
</label>
