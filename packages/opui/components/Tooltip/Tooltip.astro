---
import type { Props } from "./types.astro"

import Anchor from "../Anchor/Anchor.astro"

export const title = "Tooltip"

const { alignment, arrow, class: className, id, label, ...rest } = Astro.props
---

<Anchor
  alignment={alignment}
  class:list={["ui-tooltip", { "ui-with-arrow": arrow }, className]}
  id={id}
  trigger="hover"
  {...rest}
>
  <slot />
  <Fragment slot="anchored">
    {label}
    <slot name="content" />
  </Fragment>
</Anchor>
