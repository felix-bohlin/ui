---
import { prefixClasses as pfx } from "../utils"
import Anchor from "../Anchor/Anchor.astro"

type Props = {
  [key: string]: any
  alignment?: string
  arrow?: boolean
  class?: string
  id?: string
  label?: string
}

export const title = "Tooltip"

const { alignment, arrow, class: className, id, label, ...rest } = Astro.props
---

<Anchor
  alignment={alignment}
  class:list={pfx(["tooltip", { "with-arrow": !!arrow }, className])}
  id={id}
  trigger="hover"
  {...rest}
>
  <slot />
  <Fragment slot="anchored">
    {label}
    <slot name="content" />
  </Fragment>
</Anchor>
