---
import { Table } from "@opui/astro"
---

<Table>
  <Table.ColumnGroup>
    <Table.Column width="min-width: 20%" />
    <Table.Column width="min-width: 20%" />
    <Table.Column width="min-width: 20%" />
    <Table.Column width="min-width: 300px" />
  </Table.ColumnGroup>
  <Table.Head>
    <Table.Row>
      <Table.HeaderCell>Type</Table.HeaderCell>
      <Table.HeaderCell>Modifiers</Table.HeaderCell>
      <Table.HeaderCell>Default</Table.HeaderCell>
      <Table.HeaderCell>Description</Table.HeaderCell>
    </Table.Row>
  </Table.Head>
  <Table.Body>
    <Table.Row>
      <Table.Cell><strong>Progress</strong></Table.Cell>
      <Table.Cell
        ><code
          >&lt;div
          class="ui-progress"&gt;&lt;progress&gt;…&lt;/progress&gt;&lt;/div&gt;</code
        ></Table.Cell
      >
      <Table.Cell>-</Table.Cell>
      <Table.Cell
        >Wrapper div with the native HTML progress element inside.</Table.Cell
      >
    </Table.Row>
    <Table.Row>
      <Table.Cell><strong>Indeterminate</strong></Table.Cell>
      <Table.Cell>No <code>value</code> attribute</Table.Cell>
      <Table.Cell>-</Table.Cell>
      <Table.Cell>Display an indeterminate loading state.</Table.Cell>
    </Table.Row>
    <Table.Row>
      <Table.Cell><strong>Variant</strong></Table.Cell>
      <Table.Cell
        ><code>.ui-filled</code>, <code>.ui-default</code>, <code
          >.ui-tonal</code
        ></Table.Cell
      >
      <Table.Cell>-</Table.Cell>
      <Table.Cell
        >Modifiers on the wrapper div for different background surfaces.</Table.Cell
      >
    </Table.Row>
  </Table.Body>
</Table>
