---
import { Table } from "@opui/astro"
---

<Table>
  <Table.ColumnGroup>
    <Table.Column width="min-width: 20%" />
    <Table.Column width="min-width: 20%" />
    <Table.Column width="min-width: 20%" />
    <Table.Column width="min-width: 300px" />
  </Table.ColumnGroup>
  <Table.Head>
    <Table.Row>
      <Table.HeaderCell>Type</Table.HeaderCell>
      <Table.HeaderCell>Modifiers</Table.HeaderCell>
      <Table.HeaderCell>Default</Table.HeaderCell>
      <Table.HeaderCell>Description</Table.HeaderCell>
    </Table.Row>
  </Table.Head>
  <Table.Body>
    <Table.Row>
      <Table.Cell><strong>Table</strong></Table.Cell>
      <Table.Cell><code>&lt;table class="ui-table"&gt;</code></Table.Cell>
      <Table.Cell>-</Table.Cell>
      <Table.Cell>The native HTML table element.</Table.Cell>
    </Table.Row>
    <Table.Row>
      <Table.Cell><strong>Dense</strong></Table.Cell>
      <Table.Cell><code>.ui-dense</code></Table.Cell>
      <Table.Cell>-</Table.Cell>
      <Table.Cell>When applied the table will appear denser.</Table.Cell>
    </Table.Row>
    <Table.Row>
      <Table.Cell><strong>Spacious</strong></Table.Cell>
      <Table.Cell><code>.ui-spacious</code></Table.Cell>
      <Table.Cell>-</Table.Cell>
      <Table.Cell>When applied the table will appear more spacious.</Table.Cell>
    </Table.Row>
  </Table.Body>
</Table>
