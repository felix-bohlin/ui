---
import Document from "../layouts/Document.astro"
import FrameworkPicker from "./FrameworkPicker.astro"
import ComponentAPI from "./ComponentAPI.astro"
import { FRAMEWORKS, type FrameworkId } from "../utils/framework-routing"

const apiModules = import.meta.glob("../component-api/**/*.astro", {
  eager: true,
})

const API_LABEL_PATTERN = FRAMEWORKS.map((f) => f.label).join("|")
const LABEL_TO_ID = Object.fromEntries(
  FRAMEWORKS.map((f) => [f.label, f.id]),
) as Record<string, FrameworkId>

type ApiGroup = {
  folder: string
  prefix: string
  apis: Partial<Record<FrameworkId, any>>
}

const groups: Record<string, ApiGroup> = {}

for (const path in apiModules) {
  const parts = path.split("/")
  const folder = parts[parts.length - 2]
  const filename = parts[parts.length - 1]

  const match = filename.match(
    new RegExp(`^(.*)(${API_LABEL_PATTERN})\\.astro$`),
  )
  if (!match) continue

  const prefix = match[1]
  const frameworkId = LABEL_TO_ID[match[2]]
  if (!frameworkId) continue

  const key = `${folder}/${prefix}`
  if (!groups[key]) {
    groups[key] = { folder, prefix, apis: {} }
  }
  groups[key].apis[frameworkId] = (apiModules[path] as any).default
}

const { link } = Astro.locals

const apiList = Object.values(groups)
  .map((group) => {
    let slug = group.prefix ? group.prefix.toLowerCase() : group.folder

    const title = slug
      .split("-")
      .map((word: string) => word.charAt(0).toUpperCase() + word.slice(1))
      .join(" ")

    return {
      title,
      slug,
      apis: group.apis,
    }
  })
  .sort((a, b) => a.title.localeCompare(b.title))
---

<Document overline="API">
  <FrameworkPicker slot="sidebar" />

  <Fragment slot="title">Component API</Fragment>

  <style>
    table {
      cursor: default;
    }
    td a {
      color: currentColor;
      cursor: default;
      font-weight: inherit;
      pointer-events: none;
      text-decoration: none;
    }
  </style>

  {
    apiList.map(({ title, slug, apis }) => (
      <section>
        <h2 id={slug}>
          <a href={link(`/components/${slug}`)}>{title}</a>
        </h2>
        <ComponentAPI apis={apis} hideTitle />
      </section>
    ))
  }
</Document>
