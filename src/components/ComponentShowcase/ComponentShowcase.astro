---
import {
  Accordion,
  Avatar,
  Badge,
  Button,
  ButtonGroup,
  Callout,
  Card,
  Checkbox,
  Chip,
  DescriptionList,
  Divider,
  FieldGroup,
  IconButton,
  List,
  ListItem,
  Progress,
  Radio,
  Range,
  Select,
  Switch,
  TextField,
  Textarea,
  ToggleButton,
  ToggleGroup,
} from "@opui/astro"
import ComponentCard from "./ComponentCard.astro"
import FrameworkPicker from "../FrameworkPicker.astro"
---

<div class="component-showcase component-showcase--hero">
  <div class="component-showcase__intro">
    <slot />
  </div>

  <ComponentCard name="Accordion" href="/components/accordion" size="wide">
    <Accordion aria-hidden="true" variant="outlined">
      <Fragment slot="summary">How does it work?</Fragment>
      It's pretty simple, actually.
    </Accordion>
  </ComponentCard>

  <ComponentCard name="Anchor" href="/components/anchor">
    <div class="ui-anchor" aria-hidden="true">
      <Chip variant="outlined">Anchored</Chip>
      {
        (
          [
            { bottom: "anchor(top)", right: "anchor(left)" },
            { bottom: "anchor(top)", left: "anchor(right)" },
            { top: "anchor(bottom)", right: "anchor(left)" },
            { top: "anchor(bottom)", left: "anchor(right)" },
          ] as const
        ).map((position) => (
          <svg
            style={`position: absolute; position-anchor: --anchor; ${Object.entries(
              position,
            )
              .map(([prop, value]) => `${prop}: ${value};`)
              .join(" ")}`}
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill="currentColor"
              d="M12 22q-1.525 0-3.125-.55t-2.9-1.5t-2.137-2.225T3 15v-3l4 3l-1.55 1.55q.725 1.275 2.3 2.2T11 19.925V11H8V9h3V7.825q-.875-.325-1.437-1.088T9 5q0-1.25.875-2.125T12 2t2.125.875T15 5q0 .975-.562 1.738T13 7.825V9h3v2h-3v8.925q1.675-.25 3.25-1.175t2.3-2.2L17 15l4-3v3q0 1.45-.837 2.725t-2.138 2.225t-2.9 1.5T12 22m0-16q.425 0 .713-.287T13 5t-.288-.712T12 4t-.712.288T11 5t.288.713T12 6"
            />
          </svg>
        ))
      }
    </div>
  </ComponentCard>

  <ComponentCard name="Avatar" href="/components/avatar">
    <Avatar aria-hidden="true" isGroup>
      <Avatar
        src="https://images.unsplash.com/photo-1614530606961-c4ce986825c1?q=80&w=1827&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
        alt="Avatar"
      />
      <Avatar>OP</Avatar>
      <Avatar>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 32 32"
          ><path
            fill="currentColor"
            d="M16 2C8.268 2 2 8.268 2 16s6.268 14 14 14s14-6.268 14-14S23.732 2 16 2m0 22.5c-3.866 0-7-2.429-7-6.071A2.43 2.43 0 0 1 11.429 16h9.142A2.43 2.43 0 0 1 23 18.429c0 3.642-3.134 6.071-7 6.071m0-10A3.75 3.75 0 1 1 16 7a3.75 3.75 0 0 1 0 7.5"
          ></path></svg
        >
      </Avatar>
    </Avatar>
  </ComponentCard>

  <ComponentCard name="Badge" href="/components/badge">
    <Badge aria-hidden="true" label="3">Inbox</Badge>
  </ComponentCard>

  <ComponentCard name="Button" href="/components/button">
    <Button aria-hidden="true" variant="filled">Get started</Button>
  </ComponentCard>

  <ComponentCard name="Button Group" href="/components/button-group">
    <ButtonGroup aria-hidden="true" variant="outlined" size="small">
      <Button>Day</Button>
      <Button>Week</Button>
    </ButtonGroup>
  </ComponentCard>

  <ComponentCard name="Callout" href="/components/callout" size="wide">
    <Callout aria-hidden="true" variant="tonal" severity="neutral">
      <Fragment slot="title">Heads up!</Fragment>
      Nah, just kidding. It wasn't important.
    </Callout>
  </ComponentCard>

  <ComponentCard name="Card" href="/components/card" size="xl">
    <Card aria-hidden="true" variant="outlined">
      <Fragment slot="header">
        <p>Article</p>
        <h3>Build something nice</h3>
      </Fragment>
      <Fragment slot="content">
        Components you can copy-paste into your project.
      </Fragment>
      <Fragment slot="actions">
        <Button variant="tonal" size="small">Read</Button>
      </Fragment>
    </Card>
  </ComponentCard>

  <ComponentCard name="Checkbox" href="/components/checkbox">
    <Checkbox aria-hidden="true" checked>This checks out</Checkbox>
  </ComponentCard>

  <ComponentCard name="Chip" href="/components/chip">
    <Chip aria-hidden="true" variant="outlined">CSS</Chip>
  </ComponentCard>

  <ComponentCard name="Description List" href="/components/description-list">
    <DescriptionList aria-hidden="true" bordered="dotted">
      <DescriptionList.Item>
        <DescriptionList.Term>Name</DescriptionList.Term>
        <DescriptionList.Description>Open Props UI</DescriptionList.Description>
      </DescriptionList.Item>
      <DescriptionList.Item>
        <DescriptionList.Term>Status</DescriptionList.Term>
        <DescriptionList.Description>Awesome</DescriptionList.Description>
      </DescriptionList.Item>
    </DescriptionList>
  </ComponentCard>

  <ComponentCard name="Divider" href="/components/divider">
    <Divider variant="filled" aria-hidden="true" />
  </ComponentCard>

  <ComponentCard name="Icon Button" href="/components/icon-button">
    <IconButton variant="filled" aria-hidden="true">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M5 12h14"></path>
        <path d="M12 5v14"></path>
      </svg>
    </IconButton>
  </ComponentCard>

  <ComponentCard name="List" href="/components/list" size="wide">
    <List variant="default" aria-hidden="true" bordered dense>
      <ListItem headline="Angel Investor" description="Re: Horse thing pitch">
        <Avatar slot="start">AI</Avatar>
        <div slot="end">15:42</div>
      </ListItem>
      <ListItem
        headline="Jonathan Blow"
        description="Where are we at with the Horse Tinder programming language?"
      >
        <Avatar slot="start">JB</Avatar>
        <div slot="end">09:18</div>
      </ListItem>
    </List>
  </ComponentCard>

  <ComponentCard name="Progress" href="/components/progress" size="wide">
    <Progress variant="filled" aria-busy="true" aria-hidden="true" />
  </ComponentCard>

  <ComponentCard name="Radio" href="/components/radio">
    <FieldGroup name="index-radio-showcase" aria-hidden="true">
      <Radio checked>Whoa</Radio>
      <Radio>Nice</Radio>
    </FieldGroup>
  </ComponentCard>

  <ComponentCard name="Range" href="/components/range" size="wide">
    <Range variant="filled" aria-hidden="true" value={50} min={0} max={100} />
  </ComponentCard>

  <ComponentCard name="Select" href="/components/select">
    <FrameworkPicker />
  </ComponentCard>

  <ComponentCard name="Spinner" href="/components/spinner">
    <p aria-busy="true">Loading</p>
    <Button variant="filled" aria-busy="true">Loading</Button>
  </ComponentCard>

  <ComponentCard name="Switch" href="/components/switch">
    <Switch id="showcase-theme-switcher" aria-hidden="true">Dark mode</Switch>
  </ComponentCard>

  <ComponentCard name="TextField" href="/components/text-field">
    <TextField aria-hidden="true" placeholder="you@example.com" />
  </ComponentCard>

  <ComponentCard name="Textarea" href="/components/textarea">
    <Textarea aria-hidden="true" placeholder="Write a comment…" />
  </ComponentCard>

  <ComponentCard name="Toggle Group" href="/components/toggle">
    <ToggleGroup aria-hidden="true">
      <ToggleButton pressed size="small" aria-label="Bold">
        <strong>B</strong>
      </ToggleButton>
      <ToggleButton size="small" aria-label="Italic">
        <i>I</i>
      </ToggleButton>
      <ToggleButton size="small" aria-label="Underline">
        <u>U</u>
      </ToggleButton>
    </ToggleGroup>
  </ComponentCard>

  <style is:global>
    .component-showcase {
      display: grid;
      gap: var(--size-3);
      grid-auto-flow: dense;
      grid-auto-rows: minmax(180px, auto);
      grid-template-columns: repeat(auto-fill, minmax(min(240px, 100%), 1fr));
      margin-block: var(--size-8);
    }

    .component-showcase--hero {
      margin-block: 0 var(--size-8);
    }

    .component-showcase__intro {
      grid-column: 1 / -1;
      justify-self: start;
      align-self: start;
      padding-block: var(--size-10) var(--size-8);
      text-align: start;
    }

    @media (width > 768px) {
      .component-showcase--hero .component-showcase__intro {
        grid-column: 1 / span 2;
        grid-row: span 3;
        max-inline-size: 34rem;
        padding-block: var(--size-8) var(--size-10);
      }
    }

    @media (width <= 600px) {
      .component-showcase {
        grid-auto-rows: minmax(160px, auto);
      }
    }
  </style>
</div>

<script is:inline>
  ;(function () {
    const themeSwitcher = document.getElementById("showcase-theme-switcher")

    if (themeSwitcher) {
      const syncTheme = () => {
        themeSwitcher.checked =
          document.documentElement.classList.contains("ui-dark")
      }

      syncTheme()

      themeSwitcher.addEventListener("click", () => {
        const isDark = document.documentElement.classList.contains("ui-dark")
        const newTheme = isDark ? "light" : "dark"
        window.themeUtils.setTheme(newTheme)
        syncTheme()
      })

      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (
            mutation.type === "attributes" &&
            mutation.attributeName === "class"
          ) {
            syncTheme()
          }
        })
      })

      observer.observe(document.documentElement, { attributes: true })
    }
  })()
</script>
