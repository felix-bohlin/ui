---
import { Avatar, Tooltip } from "@opui/astro"
import historicalContributors from "../data/historical-contributors.json"

type Contributor = {
  login: string
  avatar_url: string
  html_url: string
  first_contribution_date?: string
}

const REPO = "felix-bohlin/ui"
const HEADERS = { "User-Agent": "Astro-Site-Generator" }

let contributors: Contributor[] = []
let error = ""

try {
  const response = await fetch(
    `https://api.github.com/repos/${REPO}/contributors`,
    { headers: HEADERS },
  )

  if (!response.ok) {
    error = `HTTP Error: ${response.status}`
  } else {
    const data = await response.json()
    if (!Array.isArray(data)) {
      error = "Unexpected response from GitHub"
    } else {
      const currentUsers: Contributor[] = data
        .filter((c: { type: string }) => c.type === "User")
        .map((u: { login: string; avatar_url: string; html_url: string }) => ({
          login: u.login,
          avatar_url: u.avatar_url,
          html_url: u.html_url,
        }))

      // Merge historical (static JSON) with current, current takes precedence
      const merged = new Map<string, Contributor>(
        historicalContributors.map((c) => [c.login, c]),
      )
      for (const u of currentUsers) merged.set(u.login, u)

      // Fetch first contribution date for current contributors
      contributors = await Promise.all(
        Array.from(merged.values()).map(async (user) => {
          try {
            const commitRes = await fetch(
              `https://api.github.com/repos/${REPO}/commits?author=${user.login}&per_page=1`,
              { headers: HEADERS },
            )

            if (commitRes.ok) {
              const link = commitRes.headers.get("link")
              let firstCommitDate = ""

              if (link && link.includes('rel="last"')) {
                const lastPageUrl = link.match(/<([^>]+)>; rel="last"/)?.[1]
                if (lastPageUrl) {
                  const lastPageRes = await fetch(lastPageUrl, {
                    headers: HEADERS,
                  })
                  if (lastPageRes.ok) {
                    const lastPageCommits = await lastPageRes.json()
                    firstCommitDate =
                      lastPageCommits[lastPageCommits.length - 1]?.commit
                        ?.author?.date ?? ""
                  }
                }
              } else {
                const commits = await commitRes.json()
                firstCommitDate = commits[0]?.commit?.author?.date ?? ""
              }

              if (firstCommitDate) {
                return { ...user, first_contribution_date: firstCommitDate }
              }
            }
          } catch (e) {
            // fall through
          }

          return user
        }),
      )

      contributors.sort((a, b) => {
        const dateA = a.first_contribution_date || "9999-12-31"
        const dateB = b.first_contribution_date || "9999-12-31"
        return dateA.localeCompare(dateB)
      })
    }
  }
} catch (e) {
  error = e instanceof Error ? e.message : "An unknown error occurred"
}
---

{
  !error && (
    <div class="contributors">
      {contributors.length > 0
        ? contributors.map((contributor) => (
            <Tooltip
              label={contributor.login}
              id={`tooltip-${contributor.login}`}
            >
              <Avatar
                src={contributor.avatar_url}
                alt={contributor.login}
                href={contributor.html_url}
                interestfor={`tooltip-${contributor.login}`}
                commandfor={`tooltip-${contributor.login}`}
                command="toggle-popover"
              />
            </Tooltip>
          ))
        : !error && <p>Loading contributors...</p>}
    </div>
  )
}

<style>
  .contributors {
    display: flex;
    flex-wrap: wrap;
    gap: var(--size-1);
    margin-block-start: var(--size-4);
  }
</style>
