---
import Component from "../../layouts/Component.astro"
import Example from "../../components/Example"

import AutoExample from "../../components/AutoExample.astro"
import BadgeVisibility from "../../component-examples/badge/Visibility.astro"
import BadgeVisibilityVue from "../../component-examples/badge/Visibility.vue"
import BadgeVisibilityHTML from "../../component-examples/badge/Visibility.html?raw"
import BadgeVisibilityAstro from "../../component-examples/badge/VisibilityCode.astro?raw"
import BadgeVisibilityVueRaw from "../../component-examples/badge/VisibilityCode.vue?raw"

import BadgeAnatomy from "../../component-examples/badge/Anatomy.astro"

import { Switch as UISwitch } from "@opui/astro"
import Conditional from "../../components/Conditional.astro"

import BadgeCSS from "@opui/css/components/badge.css?raw"
import AnchorCSS from "@opui/css/components/anchor.css?raw"
---

<style is:global>
  .anatomy {
    outline: var(--_anatomy-border-gray);
    outline-offset: -2px;

    & > .ui-anchor-floating > .ui-badge-indicator {
      outline: var(--_anatomy-border-red);
      outline-offset: -3px;
    }
  }
</style>

<Component
  slug="badge"
  browserSupport={["anchor-positioning"]}
  changelogPaths={[
    {
      path: "packages/opui/components/Badge/Badge.astro",
      type: "component",
    },
    { path: "src/docs/components/badge.astro", type: "docs" },
    { path: "src/component-examples/badge", type: "docs" },
    {
      path: "packages/opui/css/components/badge.css",
      type: "css",
    },
    { path: "src/component-api/badge", type: "api" },
  ]}
  installationTabs={[
    { title: "badge.css", code: BadgeCSS, lang: "css" },
    { title: "anchor.css", code: AnchorCSS, lang: "css", isDependency: true },
  ]}
>
  <Fragment slot="title">Badge</Fragment>
  <Fragment slot="preamble">
    <p>
      A badge is a small status indicator that can be placed on other elements.
    </p>
  </Fragment>

  <section>
    <h2 id="variants">Variants</h2>
    <Conditional as="p">
      <Fragment slot="astro">
        Default, and <code>dot</code>.
      </Fragment>
      <Fragment slot="html">
        Default, and <code>.ui-dot</code>.
      </Fragment>
    </Conditional>

    <AutoExample name="Variants" row />
  </section>

  <section>
    <h2 id="indicator">Indicator</h2>
    <Conditional as="p">
      <Fragment slot="astro">
        Set indicator text with the <code>label</code> prop or the <code
          >indicator</code
        > slot. The default slot holds the anchored element.
      </Fragment>
      <Fragment slot="html">
        Put indicator text inside <code>.ui-badge-indicator</code>. The anchored
        element is the badge's direct child before <code
          >.ui-anchor-floating</code
        >.
      </Fragment>
    </Conditional>

    <AutoExample name="Indicator" row />
  </section>

  <section>
    <h2 id="severities">Severities</h2>
    <Conditional>
      <p slot="html">
        <code>.ui-critical</code>, <code>.ui-info</code>, <code
          >.ui-neutral</code
        >,
        <code>.ui-success</code>, <code>.ui-warning</code>.
      </p>
      <p slot="astro">
        <code>critical</code>, <code>info</code>, <code>neutral</code>, <code
          >success</code
        >, <code>warning</code>.
      </p>
    </Conditional>

    <AutoExample name="Color" row />
  </section>

  <section>
    <h2 id="visibility">Visibility</h2>
    <Conditional as="p">
      <Fragment slot="astro">
        Change the badge's visibility using the <code>invisible</code>
        prop.
      </Fragment>
      <Fragment slot="html">
        Change the badge's visibility using the <code>.ui-invisible</code>
        class.
      </Fragment>
    </Conditional>

    <Example row>
      <Conditional slot="controls">
        <UISwitch slot="html" id="badge-visibility-toggle"
          ><code>.ui-invisible</code></UISwitch
        >
        <UISwitch slot="astro" id="badge-visibility-toggle"
          ><code>invisible</code></UISwitch
        >
      </Conditional>
      <Example.Preview slot="preview-astro" code={BadgeVisibility} />
      <Example.Preview slot="preview-html" code={BadgeVisibilityHTML} />
      <Example.Preview slot="preview-vue" code={BadgeVisibilityVue} />
      <Example.Code slot="code-html" code={BadgeVisibilityHTML} />
      <Example.Code slot="code-astro" code={BadgeVisibilityAstro} />
      <Example.Code slot="code-vue" code={BadgeVisibilityVueRaw} />
    </Example>
  </section>

  <section>
    <h2 id="alignment">Alignment</h2>
    <p>Where the badge should be placed over the child.</p>
    <Conditional>
      <p slot="html">
        <code>.ui-start-start</code>, default, <code>.ui-end-start</code>, <code
          >.ui-end-end</code
        >.
      </p>
      <p slot="astro">
        <code>start-start</code>, default,
        <code>end-start</code>, <code>end-end</code>.
      </p>
    </Conditional>

    <AutoExample name="Alignment" row spacious />
  </section>

  <Fragment slot="anatomy">
    <Conditional>
      <p slot="astro">
        The badge is composed of an anchored element (default slot), and an
        indicator (<code>label</code> prop or <code>indicator</code> slot).
      </p>
      <p slot="html">
        The badge is composed of an anchored element and a <code
          >.ui-badge-indicator</code
        > inside <code>.ui-anchor-floating</code>.
      </p>
    </Conditional>

    <Example row>
      <Example.Preview code={BadgeAnatomy} />
    </Example>
  </Fragment>
</Component>

<script>
  function setupBadgeVisibilityControls() {
    document
      .querySelectorAll<HTMLElement>(".example-container")
      .forEach((container) => {
        if (!container.querySelector("#badge-visibility-toggle")) return
        if (container.dataset.badgeVisibilitySetup) return
        container.dataset.badgeVisibilitySetup = "true"

        const sync = (checked: boolean) => {
          container.querySelectorAll(".ui-badge").forEach((badge) => {
            badge.classList.toggle("ui-invisible", checked)
          })
        }

        container.addEventListener("change", (event) => {
          const input = event.target
          if (!(input instanceof HTMLInputElement)) return
          if (input.id !== "badge-visibility-toggle") return
          sync(input.checked)
        })

        const initial = container.querySelector<HTMLInputElement>(
          "#badge-visibility-toggle",
        )
        if (initial) sync(initial.checked)
      })
  }

  setupBadgeVisibilityControls()
  document.addEventListener("astro:after-swap", setupBadgeVisibilityControls)
</script>
