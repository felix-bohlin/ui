---
import Component from "../../layouts/Component.astro"
import Example from "../../components/Example"
import AutoExample from "../../components/AutoExample.astro"
import Conditional from "../../components/Conditional.astro"

import Variants from "../../component-examples/textarea/Variants.astro"
import Sizes from "../../component-examples/textarea/Sizes.astro"
import SupportingText from "../../component-examples/textarea/SupportingText.astro"
import Affix from "../../component-examples/textarea/Affix.astro"
import Headers from "../../component-examples/textarea/Headers.astro"
import Validation from "../../component-examples/textarea/Validation.astro"
import AutoFit from "../../component-examples/textarea/AutoFit.astro"
import Orientation from "../../component-examples/textarea/Orientation.astro"
import FieldCSS from "@opui/css/components/text-field.css?raw"
import TextareaCSS from "@opui/css/components/textarea.css?raw"

import TextFieldAPIAstro from "../../component-api/text-field/Astro.astro"
import TextFieldAPIHTML from "../../component-api/text-field/HTML.astro"
import TextareaAPIAstro from "../../component-api/textarea/Astro.astro"
import TextareaAPIHTML from "../../component-api/textarea/HTML.astro"
---

<Component
  slug="textarea"
  browserSupport={[
    "datalist",
    "field-sizing",
    "has",
    "light-dark",
    "relative-color",
  ]}
  apis={[
    {
      title: "Text field API",
      astro: TextFieldAPIAstro,
      html: TextFieldAPIHTML,
    },
    { title: "Textarea API", astro: TextareaAPIAstro, html: TextareaAPIHTML },
  ]}
  changelogPaths={[
    {
      path: "packages/opui/components/Textarea/Textarea.astro",
      type: "component",
    },
    { path: "src/docs/components/textarea.astro", type: "docs" },
    { path: "src/component-examples/textarea", type: "docs" },
    {
      path: "packages/opui/css/components/textarea.css",
      type: "css",
    },
    {
      path: "packages/opui/css/components/text-field.css",
      type: "css",
    },
    { path: "src/component-api/textarea", type: "api" },
    { path: "src/component-api/text-field", type: "api" },
  ]}
  installationTabs={[
    {
      title: "text-field.css",
      code: FieldCSS,
      lang: "css",
      isDependency: true,
    },
    { title: "textarea.css", code: TextareaCSS, lang: "css" },
  ]}
>
  <Fragment slot="title">Textarea</Fragment>
  <Fragment slot="preamble">
    An input for multi-line text data. Basic textareas with labels, supporting
    text, and validation states.
  </Fragment>

  <section>
    <h2 id="variants">Variants</h2>
    <AutoExample name="Variants" row />
  </section>

  <section>
    <h2 id="sizes">Sizes</h2>
    <AutoExample name="Sizes" row />
  </section>

  <section>
    <h2 id="end-text">End text</h2>
    <AutoExample name="SupportingText" row />
  </section>

  <section>
    <h2 id="affix">Affix</h2>
    <Conditional as="p">
      <Fragment slot="astro">
        Use the <code>prefix</code>, <code>suffix</code>, <code>header</code>,
        and <code>footer</code> slots to affix content inside the textarea's border.
        Header and footer are particularly useful for filenames and character counters.
      </Fragment>
      <Fragment slot="html">
        Add <code>.ui-prefix</code>, <code>.ui-suffix</code>, <code>.ui-header</code>, or
        <code>.ui-footer</code> elements inside <code>.ui-field</code> to affix content
        inside the textarea's border.
      </Fragment>
    </Conditional>

    <AutoExample name="Affix" />

    <h3 id="headers-and-footers">Headers and footers</h3>

    <AutoExample name="Headers" column />
  </section>

  <section>
    <h2 id="validation">Validation</h2>
    <p>
      Add <code>[required]</code> to the <code>&lt;textarea&gt;</code> element to
      toggle required styles
    </p>
    <Conditional as="p">
      <Fragment slot="astro">
        The <code>critical</code> prop toggles the error styles. Make use of the end
        text to give extra feedback on the error.
      </Fragment>
      <Fragment slot="html">
        Add the <code>data-invalid</code> attribute to toggle error styles. Make use
        of the end text to give extra feedback on the error.
      </Fragment>
    </Conditional>

    <AutoExample name="Validation" />
  </section>

  <section>
    <h2 id="spread">Spread</h2>
    <Conditional as="p">
      <Fragment slot="astro">
        Use the <code>spread</code> boolean prop to display the label and description
        on the left with the textarea on the right. The layout collapses to a column
        on narrow containers.
      </Fragment>
      <Fragment slot="html">
        Add the <code>.ui-spread</code> class to display the label and description on
        the left with the textarea on the right. The layout collapses to a column
        on narrow containers.
      </Fragment>
    </Conditional>

    <AutoExample name="Orientation" column spacious />
  </section>

  <section>
    <h2 id="auto-fit">Auto-fit</h2>
    <p>When enabled the Field changes size depending on its content.</p>

    <AutoExample name="AutoFit" exampleClass="flex" />

    <div class="ui-not-rich-text"></div>
  </section>

  <Fragment slot="anatomy">
    <ol>
      <li><code>label.textarea</code>: Container element</li>
      <li><code>.ui-label</code>: Field label element</li>
      <li><code>.ui-field</code>: The boxed input area</li>
      <li>
        <code>.ui-header</code>: Optional inside-border header strip (with divider)
      </li>
      <li><code>.ui-prefix</code>: Optional inline-start affix</li>
      <li><code>&lt;textarea&gt;</code>: Textarea element</li>
      <li><code>.ui-suffix</code>: Optional inline-end affix</li>
      <li>
        <code>.ui-footer</code>: Optional inside-border footer strip (with divider)
      </li>
      <li><code>.ui-end-text</code>: Supporting text element</li>
    </ol>

    <Example>
      <label class="ui-textarea anatomy">
        <span class="ui-label">Label</span>
        <span class="ui-field">
          <span class="ui-header">Header</span>
          <span class="ui-prefix">@</span>
          <textarea placeholder="Placeholder"></textarea>
          <span class="ui-suffix">.com</span>
          <span class="ui-footer">Footer</span>
        </span>
        <span class="ui-end-text">Supporting text</span>
      </label>
    </Example>
  </Fragment>
</Component>

<style is:global>
  .ui-textarea.anatomy {
    outline: var(--_anatomy-border-gray);
    outline-offset: 6px;

    & > * {
      outline: var(--_anatomy-border-red);
    }
  }
</style>
