---
import Guide from "../../../layouts/Guide.astro"
import CodeGroup from "../../../components/CodeGroup.astro"
import { Code } from "astro-expressive-code/components"
import Theming from "./_theming.astro"
---

<Guide overline="Guide">
  <Fragment slot="title">Getting started</Fragment>
  <Fragment slot="preamble">
    OPUI ships first-class Astro components. Install the package, import what
    you need, and you're set.
  </Fragment>

  <section>
    <h2 id="installation">Install via NPM</h2>

    <CodeGroup
      tabs={[
        {
          title: "pnpm",
          code: "pnpm add opui-css open-props astro -S",
          lang: "sh",
        },
        {
          title: "npm",
          code: "npm install opui-css open-props astro -S",
          lang: "sh",
        },
      ]}
    />
  </section>

  <section>
    <h2 id="css">Import the CSS</h2>
    <p>
      Astro components ship markup only - the CSS still has to be imported in
      your app somehow. Import everything:
    </p>
    <Code code={`@import "opui-css/css/imports.css";`} lang="css" />
    <p>Or pick and choose:</p>
    <Code
      code={`@import "opui-css/open-props.css";
@import "opui-css/core/palette.css";
@import "opui-css/css/theme.css";
@import "opui-css/core/normalize.css";
@import "opui-css/css/components.css";
@import "opui-css/core/utils.css";`}
      lang="css"
    />
  </section>

  <section>
    <h2 id="usage">How to use</h2>
    <Code
      code={`---
import { Button } from "opui-css/astro"
---

<Button variant="filled">Click me</Button>`}
      lang="astro"
    />
  </section>

  <Theming />
</Guide>
