---
import Guide from "../../../layouts/Guide.astro"
import CodeGroup from "../../../components/CodeGroup.astro"
import { Code } from "astro-expressive-code/components"
import Theming from "./_theming.astro"
---

<Guide overline="Guide">
  <Fragment slot="title">Getting started</Fragment>
  <Fragment slot="preamble">
    OPUI ships first-class Astro components. Install the package, import what
    you need, and you're set.
  </Fragment>

  <section>
    <h2 id="installation">Install via NPM</h2>
    <p>Install the package to get access to the components.</p>

    <CodeGroup
      tabs={[
        { title: "pnpm", code: "pnpm add opui-css -S", lang: "sh" },
        { title: "npm", code: "npm install opui-css -S", lang: "sh" },
      ]}
    />
  </section>

  <section>
    <h2 id="usage">Use a component</h2>
    <p>Components can be imported from <code>opui-css/astro</code>:</p>

    <Code
      code={`---
import { Button } from "opui-css/astro"
---

<Button variant="filled">Click me</Button>`}
      lang="astro"
    />
  </section>

  <section>
    <h2 id="css">Load the CSS</h2>
    <p>
      Astro components ship markup only — the CSS still has to be loaded once
      per app. Import the pre-bundled theme from your global stylesheet (or a
      shared layout):
    </p>
    <Code code={`@import "opui-css/css/imports.css";`} lang="css" />
    <p>Or pick and choose pieces if you want a lighter footprint:</p>
    <Code
      code={`@import "opui-css/core/normalize.css";
@import "opui-css/core/utils.css";
@import "opui-css/css/theme.css";
@import "opui-css/css/components.css";`}
      lang="css"
    />
  </section>

  <Theming />
</Guide>
