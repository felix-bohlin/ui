---
import Guide from "../../../layouts/Guide.astro"
import { Callout } from "@opui/astro"
import { Code } from "astro-expressive-code/components"
import CodeGroup from "../../../components/CodeGroup.astro"
import DocLink from "../../../components/DocLink.astro"
import Theming from "./_theming.astro"
---

<Guide overline="Guide">
  <Fragment slot="title">Getting started</Fragment>
  <Fragment slot="preamble">
    Open Props UI is a CSS UI library exploring how next-gen HTML & CSS features
    can change the way we create components. Designed to be used by professional
    teams as well as tinkering hobbyists.
  </Fragment>

  <div class="ui-not-rich-text">
    <Callout severity="neutral">
      <p>
        Open Props UI is <u>just CSS</u>. You can copy any <DocLink
          class="ui-link"
          href="/components">component</DocLink
        > CSS straight from the docs - no install required. The rest of this page
        is for when you want the full setup.
      </p>
    </Callout>
  </div>

  <section>
    <h2 id="manual-setup">Install manually</h2>
    <p>
      The most flexible way to use OPUI. Download these files from the <a
        class="ui-link"
        target="_blank"
        href="https://github.com/felix-bohlin/ui/tree/main/packages/opui"
        ><code>packages/opui/</code> folder on GitHub</a
      > and drop them into your project.
    </p>

    <Code
      code={`├─ opui
  └─ core
     ├─ normalize.css
     ├─ palette.css
     └─ utils.css
  └─ css
     ├─ components.css
     └─ theme.css
  └─ open-props.css`}
      lang="text"
    />

    <p>
      Put it all together something like this in your main CSS. If you have your
      files in a different folder structure you'd of course need to change the
      paths.
    </p>
    <Code
      code={`@layer openprops, theme, normalize, components.root, components.extended, utils;

@import "./open-props.css";
@import "./core/palette.css";
@import "./css/theme.css";
@import "./core/normalize.css";
@import "./css/components.css";
@import "./core/utils.css";`}
      lang="css"
    />

    <h3 id="theme-generator"><code>theme.css</code> generator</h3>
    <p>
      There's a WIP visual editor for editing <code>theme.css</code> - <DocLink
        href="/guide/theme-generator">try it out</DocLink
      >!
    </p>
  </section>

  <Theming />

  <section>
    <h2 id="npm-installation">Install via NPM</h2>

    <CodeGroup
      tabs={[
        {
          title: "pnpm",
          code: "pnpm add opui-css open-props -S",
          lang: "sh",
        },
        {
          title: "npm",
          code: "npm install opui-css open-props -S",
          lang: "sh",
        },
      ]}
    />

    <h3 id="npm-usage">Usage</h3>
    <p>Either import everything:</p>
    <Code code={`@import "opui-css/css/imports.css";`} lang="css" />

    <p>Or pick and choose the parts you want to include:</p>
    <Code
      code={`@import "opui-css/open-props.css";
@import "opui-css/core/palette.css";
@import "opui-css/css/theme.css";
@import "opui-css/core/normalize.css";
@import "opui-css/css/components.css";
@import "opui-css/core/utils.css";`}
      lang="css"
    />
  </section>

  <section>
    <h2 id="cdn">Install via CDN</h2>
    <Code
      code={`<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/opui-css/dist/opui.css" />`}
      lang="html"
    />
  </section>
</Guide>
