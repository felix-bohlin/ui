---
import "@opui/css/imports.css"
import "/src/styles/base.css"
import { Toast } from "@opui/astro"
import Footer from "../components/Footer.astro"
import { Font } from "astro:assets"
import {
  DEFAULT_FRAMEWORK,
  frameworkVariantsOf,
  type FrameworkId,
} from "../utils/framework-routing"

type Props = {
  title?: string
  description?: string
  image?: string
}

const { title, description, image } = Astro.props
const pathname = Astro.url.pathname
const currentFramework = (Astro.currentLocale ??
  DEFAULT_FRAMEWORK) as FrameworkId

// Every route is mirrored across frameworks, so every page advertises its
// alternates. Each variant self-canonicalizes; rel=alternate covers the rest.
const variants = frameworkVariantsOf(pathname)
const normalize = (url: string) => url.replace(/\/+$/, "") || "/"
const currentNormalized = normalize(pathname)

const siteTitle = title ? `${title} — Open Props UI` : "Open Props UI"
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
// const imageUrl = new URL(image || "/og-image.png", Astro.site)
---

<!doctype html>
<html lang="en" data-framework={currentFramework}>
  <head>
    <Font cssVariable="--font-bricolage-grotesque" preload />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{siteTitle}</title>
    {description && <meta name="description" content={description} />}

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    {description && <meta property="og:description" content={description} />}
    <!-- <meta property="og:image" content={imageUrl} /> -->

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={siteTitle} />
    {
      description && (
        <meta property="twitter:description" content={description} />
      )
    }
    <!-- <meta property="twitter:image" content={imageUrl} /> -->

    {
      variants
        .filter((v) => normalize(v.url) !== currentNormalized)
        .map((v) => (
          <link rel="alternate" href={v.url} data-framework={v.framework} />
        ))
    }
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <slot />
    <Toast />
    <Footer />
  </body>
</html>
