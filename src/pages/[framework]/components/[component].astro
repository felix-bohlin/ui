---
import { FRAMEWORK_IDS } from "../../../utils/framework-routing"

const docs = import.meta.glob("../../../docs/components/*.astro", {
  eager: true,
})

const slugOf = (path: string) => path.split("/").pop()!.replace(".astro", "")

export function getStaticPaths() {
  const slugs = Object.keys(
    import.meta.glob("../../../docs/components/*.astro"),
  )
    .map((path) => path.split("/").pop()!.replace(".astro", ""))
    .sort()

  return FRAMEWORK_IDS.flatMap((framework) =>
    slugs.map((slug) => ({
      params: { framework, component: slug },
    })),
  )
}

const { component } = Astro.params
const match = Object.entries(docs).find(([path]) => slugOf(path) === component)
const Doc = (match![1] as { default: any }).default
---

<Doc />
