{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "paths": {
      "@opui/*": ["./packages/opui/*"],
      "@opui/astro": ["./packages/opui/astro/index.ts"]
    }
  }
}
